<script>
// ── STATE ─────────────────────────────────────────────────────────────────────
let profile = {};
let arch = {
  convention: 'nonprofit',
  customLevels: { ic:'', lead:'', mgr:'', mom:'', exec:'' },
  functions: [],
  roles: []
};
let editingRoleId = null;

// ── FUNCTIONS LIST ────────────────────────────────────────────────────────────
const DEFAULT_FUNCTIONS = [
  'Programs','Operations','Finance','Development / Fundraising',
  'Communications / Marketing','People / HR','Technology','Leadership / Executive',
  'Policy / Advocacy','Research / Evaluation','Legal / Compliance','Education'
];

const CONVENTIONS = {
  nonprofit: {
    ic: ['Coordinator','Associate','Specialist','Senior Specialist','Principal Specialist'],
    lead: ['Lead','Senior Lead'],
    manager: ['Manager','Senior Manager'],
    mom: ['Director','Senior Director','VP'],
    exec: ['Chief of Staff','COO','CFO','CHRO','CEO','Executive Director']
  },
  professional: {
    ic: ['Associate','Analyst','Senior Analyst','Principal Analyst'],
    lead: ['Lead Analyst','Senior Lead'],
    manager: ['Manager','Senior Manager'],
    mom: ['Director','Principal','VP'],
    exec: ['Senior VP','C-Suite','Executive Director']
  },
  flat: {
    ic: ['Associate','Specialist','Senior Specialist'],
    lead: ['Lead','Senior Lead'],
    manager: ['Manager'],
    mom: ['Director','Executive'],
    exec: ['Executive','Founder']
  }
};

const TRACK_LABELS = { ic:'Individual Contributor', lead:'Lead', manager:'Manager', mom:'Manager of Managers', exec:'Executive' };
const TRACK_COLORS = { ic:'var(--track-ic)', lead:'var(--track-lead)', manager:'var(--track-mgr)', mom:'var(--track-mom)', exec:'var(--track-exec)' };
const TRACK_TAG_CLASSES = { ic:'rt-track-ic', lead:'rt-track-lead', manager:'rt-track-mgr', mom:'rt-track-mom', exec:'rt-track-exec' };

// ── INIT ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  loadProfile();
  loadArch();
  renderFunctionGrid();
  renderLibrary();
  renderStats();
  animateCards();
  initSectionNav();
});

function loadProfile(){
  try{ const r = localStorage.getItem('plinth_op'); if(r) profile = JSON.parse(r); }catch(e){}
  const tw2 = (parseInt(profile.wft)||0)+(parseInt(profile.wpt6)||0)+(parseInt(profile.wpt)||0);
  const name = profile.legalName || 'No client loaded';
  document.getElementById('heroClientName').textContent = name;
  document.getElementById('heroClientMeta').textContent = `${profile.entityType||''} · ${profile.primaryState||''} · ${tw2} W-2 employees`;
  const snap = document.getElementById('profileSnap');
  if(profile.legalName){
    snap.innerHTML = `
      <div class="stat-row"><span class="stat-lbl">Org</span><span style="font-size:11px;color:var(--text-mid)">${profile.legalName}</span></div>
      <div class="stat-row"><span class="stat-lbl">W-2 Employees</span><span class="stat-val">${tw2}</span></div>
      <div class="stat-row"><span class="stat-lbl">State</span><span style="font-size:12px;color:var(--text-mid)">${profile.primaryState||'—'}</span></div>`;
  }
}

function loadArch(){
  try{
    const r = localStorage.getItem('plinth_arch');
    if(r){ const d = JSON.parse(r); Object.assign(arch, d); }
  }catch(e){}
  // Restore convention selection
  selectConvention(arch.convention || 'nonprofit', false);
  // Restore custom levels
  if(arch.customLevels){
    const idMap = { ic:'customIC', lead:'customLead', mgr:'customMgr', mom:'customMoM', exec:'customExec' };
    Object.entries(idMap).forEach(([k,elId]) => {
      const el = document.getElementById(elId);
      if(el) el.value = arch.customLevels[k] || '';
    });
  }
  // Restore custom functions
  renderFunctionGrid();
  renderLibrary();
  renderStats();
}

function saveArch(){
  // Collect custom levels
  arch.customLevels = {
    ic: document.getElementById('customIC')?.value||'',
    lead: document.getElementById('customLead')?.value||'',
    mgr: document.getElementById('customMgr')?.value||'',
    mom: document.getElementById('customMoM')?.value||'',
    exec: document.getElementById('customExec')?.value||''
  };
  localStorage.setItem('plinth_arch', JSON.stringify(arch));
  flashSave();
}

function flashSave(){
  const el = document.getElementById('saveFlash');
  el.classList.add('on');
  setTimeout(()=>el.classList.remove('on'), 1800);
}

// ── CONVENTION ───────────────────────────────────────────────────────────────
function selectConvention(name, save=true){
  arch.convention = name;
  document.querySelectorAll('.convention-card').forEach(c => c.classList.remove('selected'));
  const el = document.getElementById('conv-'+name);
  if(el) el.classList.add('selected');
  if(save) saveArch();
}

// ── FUNCTIONS ─────────────────────────────────────────────────────────────────
function renderFunctionGrid(){
  const grid = document.getElementById('functionGrid');
  if(!grid) return;
  // Merge default with custom
  const allFuncs = [...new Set([...DEFAULT_FUNCTIONS, ...arch.functions])];
  grid.innerHTML = allFuncs.map(f => {
    const active = arch.functions.includes(f) || DEFAULT_FUNCTIONS.includes(f);
    return `<label style="display:flex;align-items:center;gap:7px;padding:8px 10px;border:1px solid ${active&&arch.functions.includes(f)||DEFAULT_FUNCTIONS.includes(f)?'var(--border)':'var(--border)'};border-radius:var(--radius);cursor:pointer;font-size:12px;color:var(--text-mid);background:${arch.functions.includes(f)?'rgba(27,68,54,0.05)':'var(--white)'}">
      <input type="checkbox" ${(arch.functions.length===0||arch.functions.includes(f))?'checked':''} 
        onchange="toggleFunction('${f}',this.checked)" 
        style="width:14px;height:14px;accent-color:var(--green)"> ${f}</label>`;
  }).join('');
  // Update function dropdown in modal and filters
  updateFunctionDropdowns();
}

function toggleFunction(name, checked){
  if(checked){ if(!arch.functions.includes(name)) arch.functions.push(name); }
  else { arch.functions = arch.functions.filter(f=>f!==name); }
  saveArch();
  updateFunctionDropdowns();
}

function addCustomFunction(){
  const inp = document.getElementById('customFuncInput');
  const val = inp.value.trim();
  if(!val) return;
  if(!arch.functions.includes(val)) arch.functions.push(val);
  inp.value = '';
  renderFunctionGrid();
  saveArch();
}

function updateFunctionDropdowns(){
  const activeFuncs = arch.functions.length > 0 ? arch.functions : DEFAULT_FUNCTIONS;
  ['rFunction','filterFunction'].forEach(id => {
    const el = document.getElementById(id);
    if(!el) return;
    const cur = el.value;
    el.innerHTML = id==='filterFunction' ? '<option value="">All Functions</option>' : '<option value="">Select function</option>';
    activeFuncs.forEach(f => {
      const opt = document.createElement('option');
      opt.value = f; opt.textContent = f;
      if(f===cur) opt.selected = true;
      el.appendChild(opt);
    });
  });
}

// ── LEVEL OPTIONS ─────────────────────────────────────────────────────────────
function updateLevelOptions(){
  const track = document.getElementById('rTrack')?.value;
  const levelSel = document.getElementById('rLevel');
  if(!levelSel||!track) return;
  levelSel.innerHTML = '<option value="">Select level</option>';
  // Use custom levels if defined, else convention
  const customKey = { ic:'IC', lead:'Lead', manager:'Mgr', mom:'MoM', exec:'Exec' }[track];
  const customVal = document.getElementById('custom'+customKey)?.value;
  let levels;
  if(customVal && customVal.trim()){
    levels = customVal.split(',').map(l=>l.trim()).filter(Boolean);
  } else {
    const conv = CONVENTIONS[arch.convention] || CONVENTIONS.nonprofit;
    const convKey = { ic:'ic', lead:'lead', manager:'manager', mom:'mom', exec:'exec' }[track];
    levels = conv[convKey] || [];
  }
  levels.forEach(l => {
    const opt = document.createElement('option');
    opt.value = l; opt.textContent = l;
    levelSel.appendChild(opt);
  });
}

// ── FLSA ENGINE ───────────────────────────────────────────────────────────────
function runFLSA(){
  const track = document.getElementById('rTrack')?.value;
  const salary = parseInt(document.getElementById('rSalaryNum')?.value) || 0;
  const duty = document.getElementById('rDutyType')?.value;
  const title = document.getElementById('rTitle')?.value || '';
  const container = document.getElementById('flsaResult');
  if(!container) return;

  let status = '';
  let reasoning = '';
  const SALARY_THRESHOLD = 35568; // 2024

  if(!track){ container.innerHTML = ''; return; }

  if(track === 'ic'){
    if(duty === 'manual' || duty === 'routine'){
      status = 'nonexempt';
      reasoning = 'Individual Contributor performing manual or routine clerical duties is classified as Nonexempt. Overtime pay at 1.5x applies for hours over 40/week.';
    } else if(salary >= SALARY_THRESHOLD && (duty === 'pro-duty' || duty === 'computer' || duty === 'admin-duty')){
      status = 'exempt';
      reasoning = `Salary ($${salary.toLocaleString()}) meets the $35,568 threshold and duties suggest a potential professional or administrative exemption. Confirm duties test fully applies before finalizing. Counsel review recommended.`;
    } else if(salary > 0 && salary < SALARY_THRESHOLD){
      status = 'nonexempt';
      reasoning = `Salary ($${salary.toLocaleString()}) is below the FLSA $35,568/year ($684/week) salary threshold. Exempt classification is not available at this salary level regardless of duties. Nonexempt status applies.`;
    } else {
      status = 'review';
      reasoning = 'IC classification requires review. Enter salary and primary duty to complete the FLSA determination.';
    }
  } else if(track === 'lead'){
    if(salary >= SALARY_THRESHOLD && duty === 'admin-duty'){
      status = 'review';
      reasoning = 'Lead roles with administrative duties and sufficient salary may qualify for the administrative exemption, but the "primary duty" and "discretion and independent judgment" tests must be satisfied. The Lead track typically does not have sufficient autonomy to meet the administrative exemption. Counsel review strongly recommended.';
    } else if(salary > 0 && salary < SALARY_THRESHOLD){
      status = 'nonexempt';
      reasoning = `Salary ($${salary.toLocaleString()}) is below the $35,568 threshold. Nonexempt status applies. Lead roles frequently direct the work of others but lack formal management authority — this is a common misclassification scenario. Confirm title reflects actual authority.`;
    } else {
      status = 'review';
      reasoning = 'Lead roles are frequently misclassified. They direct work informally but lack formal management authority. Unless a valid exemption applies, most Lead roles are Nonexempt. Enter salary and review duties carefully.';
    }
  } else if(track === 'manager'){
    if(salary >= SALARY_THRESHOLD && duty === 'exec-duty'){
      status = 'exempt';
      reasoning = `Salary ($${salary.toLocaleString()}) meets threshold. Manager with executive duty classification (manages 2+ FTEs, input into hiring/firing) satisfies the FLSA executive exemption. Document the management duties and headcount in the job description.`;
    } else if(salary >= SALARY_THRESHOLD && duty === 'admin-duty'){
      status = 'exempt';
      reasoning = `Salary ($${salary.toLocaleString()}) meets threshold. Administrative exemption may apply if primary duty involves office/non-manual work directly related to management and the employee exercises discretion and independent judgment on significant matters. Confirm duties test.`;
    } else if(salary > 0 && salary < SALARY_THRESHOLD){
      status = 'nonexempt';
      reasoning = `Despite management title, salary ($${salary.toLocaleString()}) is below the $35,568 threshold. The salary basis test fails and the manager must be paid overtime. This is a compliance risk if the employee is currently being treated as exempt. Correct immediately.`;
    } else {
      status = 'review';
      reasoning = 'Enter salary and confirm duty type to complete FLSA determination for this Manager role.';
    }
  } else if(track === 'mom'){
    if(salary >= SALARY_THRESHOLD){
      status = 'exempt';
      reasoning = `Manager of Managers roles typically satisfy the executive exemption (manages managers who themselves supervise employees). Salary ($${salary.toLocaleString()}) meets the threshold. Confirm management-of-managers scope is documented in the job description.`;
    } else if(salary > 0){
      status = 'nonexempt';
      reasoning = `Salary ($${salary.toLocaleString()}) is below the $35,568 threshold. Even Director and VP-level titles do not confer exempt status if the salary basis test fails. This is a significant compliance risk.`;
    } else {
      status = 'exempt';
      reasoning = 'Manager of Managers roles typically qualify for the FLSA executive exemption. Enter salary to confirm the salary basis test is met.';
    }
  } else if(track === 'exec'){
    if(salary >= SALARY_THRESHOLD || !salary){
      status = 'exempt';
      reasoning = `Executive roles meet the FLSA executive exemption when: (1) primary duty is management, (2) customarily manages 2+ FTEs, and (3) has authority to hire/fire or whose recommendations carry significant weight. ${salary?`Salary ($${salary.toLocaleString()}) meets the threshold.`:'Enter salary to confirm salary basis test.'}`;
    } else {
      status = 'review';
      reasoning = `Salary ($${salary.toLocaleString()}) is below the $35,568 FLSA threshold. Even Executive-track roles must meet the salary basis test for exempt classification. Counsel review required.`;
    }
  }

  const cls = { exempt:'flsa-exempt', nonexempt:'flsa-nonexempt', review:'flsa-review' }[status] || 'flsa-review';
  const lbl = { exempt:'Likely Exempt', nonexempt:'Nonexempt', review:'Review Required' }[status] || 'Review Required';
  const lblCls = { exempt:'exempt', nonexempt:'nonexempt', review:'review' }[status] || 'review';
  container.innerHTML = `<div class="flsa-result ${cls}"><div class="flsa-label ${lblCls}">${lbl}</div><div class="flsa-reasoning">${reasoning}</div></div>`;
}

// ── ADD / EDIT ROLE ───────────────────────────────────────────────────────────
function openAddRole(){
  editingRoleId = null;
  clearRoleForm();
  document.getElementById('modalTitle').textContent = 'Add Role';
  document.getElementById('modalSub').textContent = 'Define the role, track, and FLSA classification';
  document.getElementById('roleModal').classList.add('open');
  updateFunctionDropdowns();
}

function openEditRole(id){
  const role = arch.roles.find(r=>r.id===id);
  if(!role) return;
  editingRoleId = id;
  document.getElementById('modalTitle').textContent = 'Edit Role';
  document.getElementById('modalSub').textContent = role.title || '';
  // Populate form
  const fields = ['rTitle','rTrack','rLevel','rFunction','rEmpType','rReportsTo','rDirectReports',
    'rSalary','rSalaryNum','rDutyType','rSummary','rResponsibilities','rMinQuals','rPrefQuals','rEssFunc','rAdvisorNotes'];
  const keys = ['title','track','level','function','empType','reportsTo','directReports',
    'salary','salaryNum','dutyType','summary','responsibilities','minQuals','prefQuals','essFunc','advisorNotes'];
  updateFunctionDropdowns();
  fields.forEach((f,i) => {
    const el = document.getElementById(f);
    if(el) el.value = role[keys[i]] || '';
  });
