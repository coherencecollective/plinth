// ── IMPORT ────────────────────────────────────────────────────────────────────
function runImport(){
  const input = document.getElementById('importInput')?.value.trim();
  if(!input){ alert('Paste in some job titles first.'); return; }
  const titles = input.split('\n').map(t=>t.trim()).filter(Boolean);
  const results = titles.map(title => analyzeTitle(title));
  renderImportResults(results);
}

function analyzeTitle(title){
  const t = title.toLowerCase();
  let track = 'ic', confidence = 'medium', flags = [], suggestion = '';

  // Executive signals
  if(/(^ceo$|^coo$|^cfo$|^chro$|^cto$|^cmo$|executive director|chief |president$)/.test(t)){ track='exec'; confidence='high'; }
  // Manager of Managers signals
  else if(/(^vp |vice president|^senior director|^director of|^director,)/.test(t)){ track='mom'; confidence='high'; }
  else if(/\bdirector\b/.test(t) && !/associate director|assistant director/.test(t)){ track='mom'; confidence='medium'; }
  // Manager signals
  else if(/\bmanager\b/.test(t)){ track='manager'; confidence='high'; }
  else if(/\bsupervisor\b/.test(t)){ track='manager'; confidence='medium'; }
  // Lead signals
  else if(/\blead\b/.test(t) || /\bteam lead\b/.test(t)){ track='lead'; confidence='high'; }
  else if(/\bsenior\b/.test(t) && !/senior director|senior vp/.test(t)){ track='ic'; confidence='medium'; flags.push('Senior IC — may have informal lead responsibilities. Confirm whether this role directs others\' work.'); }
  // IC default
  else if(/(coordinator|associate|specialist|analyst|assistant|officer|advisor)/.test(t)){ track='ic'; confidence='high'; }

  // Flag anomalies
  if(track==='manager' && /associate|coordinator|assistant/.test(t)){
    flags.push('Title contains Manager but also IC-level language. Verify actual management authority before classifying as Manager track.');
    confidence='low';
  }
  if(track==='mom' && /associate|coordinator/.test(t)){
    flags.push('Director-level title with IC language. Review scope — may be an inflated title for an IC or Manager-track role.');
    confidence='low';
  }
  if(/ii$|iii$|iv$|\bii\b|\biii\b/.test(t)){
    flags.push('Numeric suffix (II, III) detected. These often indicate leveling without a coherent level framework. Recommend converting to named levels.');
  }
  if(/senior/.test(t) && /manager/.test(t)){ track='manager'; }

  return { title, track, confidence, flags };
}

