<!-- FRAMEWORK TAB -->
<div id="view-framework" class="main">
<div>

  <!-- IN-PAGE SECTION NAV -->
  <div style="display:flex;gap:0;border-bottom:1px solid var(--border);background:var(--white);border-radius:var(--radius-md) var(--radius-md) 0 0;margin-bottom:16px;overflow:hidden;box-shadow:var(--shadow)" class="fu">
    <a href="#sec-tracks" style="font-size:11px;font-weight:400;letter-spacing:0.09em;text-transform:uppercase;color:var(--text-light);padding:11px 18px;text-decoration:none;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap" onmouseover="this.style.color='var(--green)'" onmouseout="this.style.color='var(--text-light)'">Career Tracks</a>
    <a href="#sec-convention" style="font-size:11px;font-weight:400;letter-spacing:0.09em;text-transform:uppercase;color:var(--text-light);padding:11px 18px;text-decoration:none;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap" onmouseover="this.style.color='var(--green)'" onmouseout="this.style.color='var(--text-light)'">Level Naming</a>
    <a href="#sec-functions" style="font-size:11px;font-weight:400;letter-spacing:0.09em;text-transform:uppercase;color:var(--text-light);padding:11px 18px;text-decoration:none;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap" onmouseover="this.style.color='var(--green)'" onmouseout="this.style.color='var(--text-light)'">Job Functions</a>
  </div>

  <!-- TRACK EXPLAINER -->
  <div class="card fu" id="sec-tracks">
    <div class="card-hdr">
      <div class="card-title">The Five Career Tracks</div>
      <div class="card-desc">Every role in every organization fits one of these five tracks. Classification happens here before titles or levels are assigned.</div>
    </div>
    <div class="card-body">
      <div class="track-legend">
        <div class="track-pill tp-ic"><div class="track-dot td-ic"></div>Individual Contributor</div>
        <div class="track-pill tp-lead"><div class="track-dot td-lead"></div>Lead</div>
        <div class="track-pill tp-mgr"><div class="track-dot td-mgr"></div>Manager</div>
        <div class="track-pill tp-mom"><div class="track-dot td-mom"></div>Manager of Managers</div>
        <div class="track-pill tp-exec"><div class="track-dot td-exec"></div>Executive</div>
      </div>
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid var(--border)">
            <th style="padding:8px 16px 8px 0;font-size:10px;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-light);text-align:left;width:200px">Track</th>
            <th style="padding:8px 0;font-size:10px;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-light);text-align:left">Scope &amp; Authority</th>
            <th style="padding:8px 0;font-size:10px;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-light);text-align:left;width:140px">FLSA Default</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:14px 16px 14px 0;vertical-align:top">
              <div style="display:flex;align-items:center;gap:8px">
                <div style="width:3px;height:36px;background:var(--track-ic);border-radius:2px;flex-shrink:0"></div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--green)">Individual Contributor</div>
              </div>
            </td>
            <td style="padding:14px 16px 14px 0;font-size:12px;color:var(--text-mid);line-height:1.65;vertical-align:top">Executes independently. No direction of others' work. Can deepen expertise indefinitely without moving into management. Depth of impact grows within the function.</td>
            <td style="padding:14px 0;font-size:11px;color:var(--text-light);vertical-align:top;line-height:1.5">Varies — salary threshold and duties test required. Often nonexempt at junior levels.</td>
          </tr>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:14px 16px 14px 0;vertical-align:top">
              <div style="display:flex;align-items:center;gap:8px">
                <div style="width:3px;height:36px;background:var(--track-lead);border-radius:2px;flex-shrink:0"></div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--mauve)">Lead</div>
              </div>
            </td>
            <td style="padding:14px 16px 14px 0;font-size:12px;color:var(--text-mid);line-height:1.65;vertical-align:top">Directs work of interns, part-time staff, or peers on a project. No formal management authority — no hiring input, no performance reviews, no org chart accountability. Still primarily a doer. <em>Most commonly misclassified as Manager.</em></td>
            <td style="padding:14px 0;font-size:11px;color:var(--text-light);vertical-align:top;line-height:1.5">Usually nonexempt unless salary threshold and administrative exemption duties are met. High misclassification risk.</td>
          </tr>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:14px 16px 14px 0;vertical-align:top">
              <div style="display:flex;align-items:center;gap:8px">
                <div style="width:3px;height:36px;background:var(--track-mgr);border-radius:2px;flex-shrink:0"></div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:#8a6010">Manager</div>
              </div>
            </td>
            <td style="padding:14px 16px 14px 0;font-size:12px;color:var(--text-mid);line-height:1.65;vertical-align:top">Formal management authority over ICs and/or Leads. Accountable for team performance. Participates in hiring decisions and performance documentation. Manages people — not other managers.</td>
            <td style="padding:14px 0;font-size:11px;color:var(--text-light);vertical-align:top;line-height:1.5">Exempt under executive exemption if salary threshold met and duties test satisfied. Salary below $35,568 = nonexempt regardless of title.</td>
          </tr>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:14px 16px 14px 0;vertical-align:top">
              <div style="display:flex;align-items:center;gap:8px">
                <div style="width:3px;height:36px;background:var(--track-mom);border-radius:2px;flex-shrink:0"></div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--crimson)">Manager of Managers</div>
              </div>
            </td>
            <td style="padding:14px 16px 14px 0;font-size:12px;color:var(--text-mid);line-height:1.65;vertical-align:top">Manages other Managers. Strategic scope, cross-functional coordination, budget authority. Rarely in day-to-day execution. Director and VP-level roles typically land here.</td>
            <td style="padding:14px 0;font-size:11px;color:var(--text-light);vertical-align:top;line-height:1.5">Exempt under executive exemption when salary threshold met. Salary threshold failure is a critical compliance risk at this level.</td>
          </tr>
          <tr>
            <td style="padding:14px 16px 14px 0;vertical-align:top">
              <div style="display:flex;align-items:center;gap:8px">
                <div style="width:3px;height:36px;background:var(--track-exec);border-radius:2px;flex-shrink:0"></div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--green-deep)">Executive</div>
              </div>
            </td>
            <td style="padding:14px 16px 14px 0;font-size:12px;color:var(--text-mid);line-height:1.65;vertical-align:top">Sets organizational direction. Accountable to board or CEO. Organization-wide scope and impact. C-suite and Executive Director roles. Compensation decisions, strategic planning, external representation.</td>
            <td style="padding:14px 0;font-size:11px;color:var(--text-light);vertical-align:top;line-height:1.5">Exempt under executive exemption. Confirm salary threshold is met. Document management duties and hiring/firing authority.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- NAMING CONVENTION -->
  <div class="card fu" id="sec-convention" style="animation-delay:0.07s">
    <div class="card-hdr">
      <div class="card-title">Level Naming Convention</div>
      <div class="card-desc">Choose the naming system that fits this org's culture, or define custom level names. This drives how roles are titled in job descriptions and the level matrix.</div>
    </div>
    <div class="card-body">
      <div class="convention-grid" id="conventionGrid">
        <div class="convention-card selected" onclick="selectConvention('nonprofit')" id="conv-nonprofit">
          <div class="convention-name">Nonprofit / Mission-Driven</div>
          <div style="margin-top:10px;display:flex;flex-direction:column;gap:0">
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Individual Contributor</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Coordinator &nbsp;|&nbsp; Associate &nbsp;|&nbsp; Specialist &nbsp;|&nbsp; Senior Specialist</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Lead</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Lead &nbsp;|&nbsp; Senior Lead</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Manager</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Manager &nbsp;|&nbsp; Senior Manager</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Manager of Managers</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Director &nbsp;|&nbsp; Senior Director &nbsp;|&nbsp; VP</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Executive</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Chief of Staff &nbsp;|&nbsp; COO &nbsp;|&nbsp; CEO &nbsp;|&nbsp; Executive Director</div>
          </div>
        </div>
        <div class="convention-card" onclick="selectConvention('professional')" id="conv-professional">
          <div class="convention-name">Professional Services</div>
          <div style="margin-top:10px;display:flex;flex-direction:column;gap:0">
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Individual Contributor</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Associate &nbsp;|&nbsp; Analyst &nbsp;|&nbsp; Senior Analyst</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Lead</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Lead Analyst &nbsp;|&nbsp; Senior Lead</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Manager</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Manager &nbsp;|&nbsp; Senior Manager</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Manager of Managers</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Director &nbsp;|&nbsp; Principal &nbsp;|&nbsp; VP</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Executive</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Senior VP &nbsp;|&nbsp; C-Suite &nbsp;|&nbsp; Executive Director</div>
          </div>
        </div>
        <div class="convention-card" onclick="selectConvention('flat')" id="conv-flat">
          <div class="convention-name">Flat / Growth-Stage</div>
          <div style="margin-top:10px;display:flex;flex-direction:column;gap:0">
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Individual Contributor</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Associate &nbsp;|&nbsp; Specialist &nbsp;|&nbsp; Senior Specialist</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Lead</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Lead &nbsp;|&nbsp; Senior Lead</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Manager</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Manager</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Manager of Managers</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Director &nbsp;|&nbsp; Executive</div>
            <div style="font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);margin:8px 0 6px;padding-bottom:5px;border-bottom:1px solid var(--border)">Executive</div>
            <div style="font-size:10.5px;color:var(--text-mid);line-height:1.9">Executive &nbsp;|&nbsp; Founder</div>
          </div>
        </div>
      </div>
      <div class="div" style="margin-top:16px"></div>
      <div class="div-lbl">Custom Level Names</div>
      <div class="fg g2">
        <div class="f"><label>IC Levels <span class="tip">(comma-separated, lowest to highest)</span></label><input type="text" id="customIC" placeholder="e.g., Associate, Specialist, Senior Specialist" oninput="saveArch()"></div>
        <div class="f"><label>Lead Levels</label><input type="text" id="customLead" placeholder="e.g., Lead, Senior Lead" oninput="saveArch()"></div>
        <div class="f"><label>Manager Levels</label><input type="text" id="customMgr" placeholder="e.g., Manager, Senior Manager" oninput="saveArch()"></div>
        <div class="f"><label>Manager of Managers Levels</label><input type="text" id="customMoM" placeholder="e.g., Director, Senior Director, VP" oninput="saveArch()"></div>
        <div class="f c2"><label>Executive Levels</label><input type="text" id="customExec" placeholder="e.g., Chief of Staff, COO, CEO, Executive Director" oninput="saveArch()"></div>
      </div>
      <div class="al al-i" style="margin-top:12px">
        <span class="al-ic">ℹ</span>
        <span>Custom levels override the selected convention for this org. Leave blank to use the selected convention above. Level names appear on job descriptions and the level matrix.</span>
      </div>
    </div>
  </div>

  <!-- JOB FUNCTIONS -->
  <div class="card fu" id="sec-functions" style="animation-delay:0.12s">
    <div class="card-hdr">
      <div class="card-title">Job Functions</div>
      <div class="card-desc">Select the functions that exist in this organization. These become the job families in the role library and the level matrix.</div>
    </div>
    <div class="card-body">
      <div id="functionGrid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px"></div>
      <div class="fg g2">
        <div class="f">
          <label>Add Custom Function</label>
          <div style="display:flex;gap:8px">
            <input type="text" id="customFuncInput" placeholder="e.g., Research, Advocacy, Policy">
            <button onclick="addCustomFunction()" style="padding:8px 14px;background:var(--green);color:var(--white);border:none;border-radius:var(--radius);font-family:'Jost',sans-serif;font-size:12px;cursor:pointer;white-space:nowrap">Add</button>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sb-panel">
    <div class="sbph"><div class="sbpt">Architecture Summary</div><div class="sbps">Current state</div></div>
    <div class="sbpb">
      <div class="stat-row"><span class="stat-lbl">Total Roles</span><span class="stat-val" id="statTotal">0</span></div>
      <div class="stat-row"><span class="stat-lbl">Individual Contributor</span><span class="stat-val" id="statIC">0</span></div>
      <div class="stat-row"><span class="stat-lbl">Lead</span><span class="stat-val" id="statLead">0</span></div>
      <div class="stat-row"><span class="stat-lbl">Manager</span><span class="stat-val" id="statMgr">0</span></div>
      <div class="stat-row"><span class="stat-lbl">Manager of Managers</span><span class="stat-val" id="statMoM">0</span></div>
      <div class="stat-row"><span class="stat-lbl">Executive</span><span class="stat-val" id="statExec">0</span></div>
      <div class="stat-row"><span class="stat-lbl">FLSA Review Needed</span><span class="stat-val" id="statReview" style="color:var(--crimson)">0</span></div>
    </div>
  </div>
  <div class="sb-panel">
    <div class="sbph"><div class="sbpt">Profile Snapshot</div><div class="sbps">From Tool 01</div></div>
    <div class="sbpb" id="profileSnap">
      <div style="font-size:11px;color:var(--text-light)">No profile loaded.</div>
    </div>
  </div>
</div>
</div>

<!-- LIBRARY TAB -->
<div id="view-library" class="main wide" style="display:none">
  <div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px" class="fu">
      <div>
        <select id="filterTrack" onchange="renderLibrary()" style="width:auto;display:inline-block;margin-right:8px;font-size:12px;padding:6px 28px 6px 10px">
          <option value="">All Tracks</option>
          <option value="ic">Individual Contributor</option>
          <option value="lead">Lead</option>
          <option value="manager">Manager</option>
          <option value="mom">Manager of Managers</option>
          <option value="exec">Executive</option>
        </select>
        <select id="filterFunction" onchange="renderLibrary()" style="width:auto;display:inline-block;font-size:12px;padding:6px 28px 6px 10px">
          <option value="">All Functions</option>
        </select>
      </div>
      <button class="nbtn nbtn-gold" onclick="openAddRole()">+ Add Role</button>
    </div>
    <div class="role-grid" id="roleGrid"></div>
  </div>
</div>

<!-- MATRIX TAB -->
<div id="view-matrix" class="main wide" style="display:none">
  <div class="card fu">
    <div class="card-hdr">
      <div class="card-title">Level Matrix</div>
      <div class="card-desc">All roles organized by track and function. Use this to identify gaps, duplicate titles, and misaligned levels.</div>
    </div>
    <div class="card-body">
      <div id="matrixContent" style="overflow-x:auto"></div>
    </div>
  </div>
</div>

<!-- IMPORT TAB -->
<div id="view-import" class="main wide" style="display:none">
  <div>
    <div class="card fu">
      <div class="card-hdr">
        <div class="card-title">Import Existing Roles</div>
        <div class="card-desc">Paste in a list of current job titles. Plinth will sort each into the five-track architecture, flag misalignments, and suggest corrections — giving you a starting point to clean up rather than build from scratch.</div>
      </div>
      <div class="card-body">
        <div class="al al-i" style="margin-bottom:14px">
          <span class="al-ic">ℹ</span>
          <span>Paste one job title per line. Include the title exactly as it currently appears — Plinth will analyze the language and assign a track, flag anomalies, and surface misalignments for your review. You confirm or correct each before it goes into the library.</span>
        </div>
        <div class="import-area">
          <textarea id="importInput" placeholder="Program Coordinator&#10;Senior Program Manager&#10;Director of Operations&#10;Development Associate&#10;Chief Executive Officer&#10;Communications Specialist II&#10;..."></textarea>
        </div>
