function exportSingleJD(id, mode){
  const role = arch.roles.find(r=>r.id===id);
  if(!role) return;
  const html = buildJDHTML(role, mode);
  const blob = new Blob([html],{type:'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${role.title.replace(/\s+/g,'-')}_JD${mode==='internal'?'_Internal':''}.html`;
  a.click();
  URL.revokeObjectURL(a.href);
}

function exportAllJDs(mode){
  if(arch.roles.length===0){ alert('No roles in the library yet.'); return; }
  if(mode==='docx'){ exportAllJDsDocx(); return; }
  // For HTML: zip would be ideal but without a library, export each individually
  arch.roles.forEach((role,i) => {
    setTimeout(()=>{
      const html = buildJDHTML(role, mode);
      const blob = new Blob([html],{type:'text/html'});
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `${role.title.replace(/\s+/g,'-')}_JD${mode==='internal'?'_Internal':''}.html`;
      a.click();
      URL.revokeObjectURL(a.href);
    }, i * 300);
  });
}

async function exportAllJDsDocx(){
  if(typeof docx==='undefined'){ alert('Word export library not loaded. Check your connection.'); return; }
  const { Document, Paragraph, TextRun, HeadingLevel, PageBreak, AlignmentType, BorderStyle } = docx;
  const orgName = profile.legalName || '[Organization Name]';
  const children = [];

  arch.roles.forEach((role, i) => {
    if(i > 0) children.push(new Paragraph({ children:[new PageBreak()] }));
    children.push(new Paragraph({ children:[new TextRun({ text: role.title, size:36, bold:true, color:'1b4436', font:'Georgia' })], spacing:{before:0,after:120} }));
    children.push(new Paragraph({ children:[new TextRun({ text:`${orgName} · ${role.function||''} · ${TRACK_LABELS[role.track]||''} · ${role.level||''}`, size:18, color:'777777', font:'Arial' })], spacing:{before:0,after:60} }));
    if(role.salary) children.push(new Paragraph({ children:[new TextRun({ text:`Salary Range: ${role.salary}`, size:18, color:'444444', font:'Arial' })], spacing:{before:0,after:160} }));
    if(role.summary) children.push(new Paragraph({ children:[new TextRun({ text:role.summary, size:22, font:'Georgia' })], spacing:{before:60,after:160} }));
    const addSection = (heading, text) => {
      if(!text) return;
      children.push(new Paragraph({ children:[new TextRun({ text:heading, size:24, bold:true, font:'Georgia' })], spacing:{before:200,after:80}, border:{ bottom:{style:BorderStyle.SINGLE,size:4,color:'e0d8cf',space:4} } }));
      text.split('\n').filter(Boolean).forEach(line => {
        children.push(new Paragraph({ children:[new TextRun({ text:line.trim(), size:22, font:'Georgia' })], bullet:{level:0}, spacing:{before:40,after:40} }));
      });
    };
    addSection('Key Responsibilities', role.responsibilities);
    addSection('Minimum Qualifications', role.minQuals);
    addSection('Preferred Qualifications', role.prefQuals);
    addSection('Essential Functions', role.essFunc);
  });

  const doc = new Document({
    creator:'The Coherence Collective — Plinth',
    title:`${orgName} — Job Descriptions`,
    sections:[{ properties:{ page:{ margin:{top:1080,bottom:1080,left:1260,right:1260} } }, children }]
  });
  try{
    const blob = await docx.Packer.toBlob(doc);
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${orgName.replace(/\s+/g,'-')}_JobDescriptions.docx`;
    a.click();
    URL.revokeObjectURL(a.href);
  }catch(e){ console.error(e); alert('Export failed. Try the HTML option.'); }
}

function exportArchSummary(){
  const orgName = profile.legalName || '[Organization Name]';
  const tracks = ['exec','mom','manager','lead','ic'];
  let sections = tracks.map(t => {
    const roles = arch.roles.filter(r=>r.track===t);
    if(!roles.length) return '';
    return `<div style="margin-bottom:24px">
      <h2 style="font-size:13pt;font-weight:600;color:#1b4436;border-bottom:1px solid #e0d8cf;padding-bottom:6px;margin-bottom:12px">${TRACK_LABELS[t]}</h2>
      ${roles.map(r=>`<div style="padding:8px 0;border-bottom:1px solid #f0ebe4;display:flex;justify-content:space-between;align-items:center">
        <div><span style="font-size:11pt">${r.title}</span><span style="font-size:9pt;color:#777;margin-left:12px">${r.function||''} · ${r.level||''}</span></div>
        <span style="font-size:9pt;color:${r.flsaStatus==='exempt'?'#5a6020':r.flsaStatus==='nonexempt'?'#6a5020':'#A42F30'}">${{exempt:'Exempt',nonexempt:'Nonexempt',review:'FLSA Review'}[r.flsaStatus]||'Review'}</span>
      </div>`).join('')}
    </div>`;
  }).join('');
  const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${orgName} — Job Architecture</title>
  <style>body{font-family:Georgia,serif;font-size:11pt;color:#1a1a1a;max-width:680px;margin:0 auto;padding:40px 32px;line-height:1.7;}h1{font-size:22pt;font-weight:400;color:#1b4436;}@page{size:letter;margin:1in;}</style>
  </head><body>
  <h1>${orgName}</h1>
  <p style="font-size:9pt;color:#777;margin-bottom:32px">Job Architecture Summary · ${new Date().toLocaleDateString()} · The Coherence Collective</p>
  ${sections}
  </body></html>`;
  const blob = new Blob([html],{type:'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${orgName.replace(/\s+/g,'-')}_ArchSummary.html`;
  a.click();
  URL.revokeObjectURL(a.href);
}

function exportFLSALog(){
  const orgName = profile.legalName || '[Organization Name]';
  let lines = [`FLSA Classification Log`, `${orgName}`, `Generated: ${new Date().toLocaleDateString()}`, `The Coherence Collective — Plinth`, '='.repeat(50),''];
  ['exempt','nonexempt','review'].forEach(status => {
    const roles = arch.roles.filter(r=>r.flsaStatus===status);
    if(!roles.length) return;
    lines.push({exempt:'LIKELY EXEMPT',nonexempt:'NONEXEMPT',review:'REVIEW REQUIRED'}[status]);
    lines.push('-'.repeat(30));
    roles.forEach(r => {
      lines.push(`${r.title} | ${TRACK_LABELS[r.track]||r.track} | ${r.function||'—'}`);
      lines.push(`  Salary: ${r.salary||'Not entered'}`);
      lines.push(`  Reasoning: ${r.flsaReasoning||'Not completed'}`);
      lines.push('');
    });
    lines.push('');
  });
  const blob = new Blob([lines.join('\n')],{type:'text/plain'});
  const a = document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=`${orgName.replace(/\s+/g,'-')}_FLSA_Log.txt`;
  a.click();
  URL.revokeObjectURL(a.href);
}

function exportLevelMatrix(){
  const orgName = profile.legalName || '[Organization Name]';
  let lines = [`Level Matrix — ${orgName}`, `Generated: ${new Date().toLocaleDateString()}`, ''];
  ['exec','mom','manager','lead','ic'].forEach(t => {
    const roles = arch.roles.filter(r=>r.track===t);
    if(!roles.length) return;
    lines.push(TRACK_LABELS[t].toUpperCase());
    roles.forEach(r => lines.push(`  ${r.level||'—'} · ${r.title} · ${r.function||'—'}`));
    lines.push('');
  });
  const blob = new Blob([lines.join('\n')],{type:'text/plain'});
  const a = document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=`${orgName.replace(/\s+/g,'-')}_LevelMatrix.txt`;
  a.click();
  URL.revokeObjectURL(a.href);
}

// ── TABS ─────────────────────────────────────────────────────────────────────
function showTab(tab){
  ['framework','library','matrix','import','export'].forEach(t => {
    const view = document.getElementById('view-'+t);
    if(view) view.style.display = t===tab ? (t==='framework'?'grid':'block') : 'none';
    const tabEl = document.getElementById('tab-'+t);
    if(tabEl) tabEl.classList.toggle('active', t===tab);
  });
  if(tab==='library') renderLibrary();
  if(tab==='matrix') renderMatrix();
}

// ── ANIMATIONS ────────────────────────────────────────────────────────────────
function animateCards(){
  const obs = new IntersectionObserver(es=>{ es.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('vis'); }); },{threshold:0.04});
  document.querySelectorAll('.card').forEach(c=>obs.observe(c));
}
