  if(!container) return;
  if(arch.roles.length === 0){ container.innerHTML='<div style="padding:20px;font-size:12px;color:var(--text-light)">No roles in the library yet. Add roles to see the matrix.</div>'; return; }

  let html = `<table style="border-collapse:collapse;width:100%;font-size:12px">
    <thead><tr style="background:rgba(27,68,54,0.06)">
      <th style="padding:8px 12px;text-align:left;border-bottom:2px solid var(--border);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);white-space:nowrap">Track</th>
      ${usedFuncs.map(f=>`<th style="padding:8px 12px;text-align:left;border-bottom:2px solid var(--border);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-light);white-space:nowrap">${f}</th>`).join('')}
    </tr></thead><tbody>`;

  tracks.forEach(track => {
    const trackRoles = arch.roles.filter(r=>r.track===track);
    if(trackRoles.length === 0) return;
    html += `<tr><td style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:11px;font-weight:400;color:${TRACK_COLORS[track]};white-space:nowrap;vertical-align:top">${TRACK_LABELS[track]}</td>`;
    usedFuncs.forEach(func => {
      const matching = trackRoles.filter(r=>r.function===func);
      html += `<td style="padding:8px 12px;border-bottom:1px solid var(--border);vertical-align:top">`;
      if(matching.length){
        matching.forEach(r => {
          html += `<div style="margin-bottom:4px"><span style="font-size:11px;color:var(--text-dark)">${r.title}</span>`;
          if(r.level) html += `<span style="font-size:9px;color:var(--text-light);margin-left:4px">${r.level}</span>`;
          if(r.flsaStatus==='review') html += `<span style="font-size:9px;color:var(--crimson);margin-left:4px">⚠ FLSA</span>`;
          html += `</div>`;
        });
      } else { html += `<span style="color:var(--border)">—</span>`; }
      html += `</td>`;
    });
    html += `</tr>`;
  });
  html += `</tbody></table>`;
  container.innerHTML = html;
}

